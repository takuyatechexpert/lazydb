# Direct 接続 (PostgreSQL)
- name: local-pg
  label: local
  type: direct
  host: 127.0.0.1
  port: 5432
  database: myapp_dev
  user: postgres
  password: "env:PGPASSWORD"        # env:VAR / prompt / 平文
  # db_type: postgresql             # デフォルト: postgresql（省略可）

# Direct 接続 (MySQL)
- name: local-mysql
  label: local
  type: direct
  db_type: mysql
  host: 127.0.0.1
  port: 3306
  database: myapp_dev
  user: root
  password: "env:MYSQL_PWD"

# SQLite 接続（ローカルファイル）
- name: local-sqlite
  label: local
  type: sqlite
  # readonly: true                  # 読み取り専用で開く
  path: ~/data/myapp.db             # チルダ展開対応 / `:memory:` も可

# Redis 接続
# クエリエディタには Redis コマンドをそのまま入力する（例: `GET foo` / `KEYS user:*` / `HGETALL myhash`）
# サイドバーには論理 DB 番号（db0 / db1 …）が表示される
- name: local-redis
  label: local
  type: direct
  db_type: redis
  host: 127.0.0.1
  port: 6379
  database: "0"                     # 論理 DB 番号（文字列で指定。SELECT n でセッション中の切替も可）
  user: ""                          # Redis ではユーザー指定なし（ACL 利用時のみ）
  # password: "env:REDIS_PASSWORD"  # AUTH パスワード（不要なら省略）
  # readonly: true                  # SET / DEL / FLUSH 等の書き込み系コマンドをブロック

# SSH トンネル
- name: staging
  label: stg
  type: ssh
  readonly: true
  ssh_host: bastion-stg             # ~/.ssh/config の Host エイリアス可
  # ssh_user: ec2-user              # 省略時は SSH config に委譲
  remote_db_host: db.example.internal
  remote_db_port: 5432
  local_port: 15432
  database: staging_db
  user: postgres
  password: "prompt"                # 起動時に対話入力

# AWS SSM トンネル
- name: production
  label: prd
  type: ssm
  readonly: true
  instance_id: i-XXXXXXXXXXXXXXXXX
  ssh_user: ec2-user
  ssh_key: ~/.ssh/id_rsa
  aws_profile: my-profile
  remote_db_host: db.example.internal
  remote_db_port: 5432
  local_port: 15433
  database: prod_db
  user: postgres
  password: "prompt"
